# Smart Disaster Coordination System - Environment Configuration
# Copy this file to .env and fill in your own values.

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/disaster_coordination

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Admin SDK
# Required for FCM push notifications and Realtime Database live-location sync.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Web Push (VAPID keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_MAILTO=mailto:your@email.com
